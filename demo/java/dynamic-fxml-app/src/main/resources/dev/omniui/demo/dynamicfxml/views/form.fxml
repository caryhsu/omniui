<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.omniui.demo.dynamicfxml.controller.FormController"
      spacing="12">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <Label text="Create User" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="80"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
        </columnConstraints>

        <Label text="Name:"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField"  promptText="Enter name"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" promptText="Enter email"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Role:"  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="8">
        <Button fx:id="submitBtn" text="Submit" onAction="#handleSubmit"/>
        <Button fx:id="clearBtn"  text="Clear"  onAction="#handleClear"/>
    </HBox>

    <Label fx:id="statusLabel" text=""/>
</VBox>
